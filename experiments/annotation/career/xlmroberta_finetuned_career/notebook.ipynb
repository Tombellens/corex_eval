ild label mapping\"\n   ],\n   \"id\": \"af4b272dfdcc4524\"\n  },\n  {\n   \"cell_type\": \"code\",\n   \"metadata\": {\n    \"ExecuteTime\": {\n     \"end_time\": \"2026-03-20T15:50:59.552485647Z\",\n     \"start_time\": \"2026-03-20T15:50:59.489804244Z\"\n    }\n   },\n   \"source\": [\n    \"unique_labels = sorted(train_df[\\\"career_position\\\"].unique())\\n\",\n    \"label2id = {lbl: i for i, lbl in enumerate(unique_labels)}\\n\",\n    \"id2label = {i: lbl for i, lbl in enumerate(unique_labels)}\\n\",\n    \"num_labels = len(unique_labels)\\n\",\n    \"\\n\",\n    \"print(f\\\"{num_labels} unique career_position codes:\\\")\\n\",\n    \"for code in unique_labels:\\n\",\n    \"    print(f\\\"  {code}\\\")\"\n   ],\n   \"id\": \"8449330a4b584e68\",\n   \"outputs\": [\n    {\n     \"name\": \"stdout\",\n     \"output_type\": \"stream\",\n     \"text\": [\n      \"186 unique career_position codes:\\n\",\n      \"  101 = President\\n\",\n      \"  102 = Deputy President\\n\",\n      \"  103 = Prime minister\\n\",\n      \"  104 = Deputy prime minister\\n\",\n      \"  105 = Minister with portfolio\\n\",\n      \"  105 = Minister with portfolio (including European Commisioner)\\n\",\n      \"  105 = Minister with portfolio (including European Commissioner)\\n\",\n      \"  106 = Minister without portfolio (also to be chosen if portfolio is unknown)\\n\",\n      \"  107 = Deputy minister same ministry\\n\",\n      \"  107 = Deputy minister same ministry (including CoG and presidential offices, see above)\\n\",\n      \"  108 = Deputy minister other ministry\\n\",\n      \"  109 = Deputy minister, unknown whether same or other ministry\\n\",\n      \"  110 = Head of ministerial cabinet same ministry\\n\",\n      \"  110 = Head of ministerial cabinet same ministry (note, same ministry also refers to prime minister’s office and presidential office)\\n\",\n      \"  111 = Head of ministerial cabinet other ministry\\n\",\n      \"  112 = Head of ministerial cabinet, unkno